// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoundStatus {
  DRAFT
  OPEN
  CLOSED
}

enum AnswerOption {
  A
  B
  C
  D
}

model QuizRound {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  status        RoundStatus @default(DRAFT)

  durationMs    Int         @default(15000)
  openedAt      DateTime?
  closesAt      DateTime?
  closedAt      DateTime?

  questions     Question[]
  responses     QuizResponse[]

  @@index([status, createdAt])
}

model Question {
  id            String       @id @default(cuid())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  roundId       String
  round         QuizRound    @relation(fields: [roundId], references: [id], onDelete: Cascade)

  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption AnswerOption?

  responses     QuizResponse[]

  @@index([roundId])
}

model Participant {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String

  responses QuizResponse[]
}

model QuizResponse {
  id            String       @id @default(cuid())
  createdAt     DateTime     @default(now())

  roundId       String
  participantId String
  questionId    String
  option        AnswerOption
  submittedAt   DateTime     @default(now())

  // milliseconds since round opened (server derived)
  latencyMs     Int?

  round         QuizRound    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  participant   Participant  @relation(fields: [participantId], references: [id], onDelete: Cascade)
  question      Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([roundId, participantId, questionId])
  @@index([roundId])
  @@index([participantId])
  @@index([questionId])
}
